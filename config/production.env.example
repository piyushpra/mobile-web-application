# Production backend environment
APP_ENV=production
PORT=4000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mobile_app
MYSQL_PASSWORD=change-production-db-password
MYSQL_DATABASE=mobile_app_db
MYSQL_POOL_SIZE=20

SESSION_TTL_MS=315360000000
MAX_ITEM_UPLOAD_COUNT=5
MAX_ITEM_UPLOAD_BYTES=5242880
APP_UPDATE_MANIFEST_CACHE_MS=15000

APP_NAME=Mobile Application
AUTH_PUBLIC_BASE_URL=http://13.235.49.124:4000
AUTH_RESET_TOKEN_TTL_MS=900000
AUTH_RESET_REQUEST_COOLDOWN_MS=60000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey-or-username
SMTP_PASSWORD=change-production-smtp-password
SMTP_FROM=Mobile Application <no-reply@example.com>
