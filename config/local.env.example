# Local backend environment
APP_ENV=local
PORT=4000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mobile_app
MYSQL_PASSWORD=change-local-db-password
MYSQL_DATABASE=mobile_app_db
MYSQL_POOL_SIZE=10

SESSION_TTL_MS=315360000000
MAX_ITEM_UPLOAD_COUNT=5
MAX_ITEM_UPLOAD_BYTES=5242880
APP_UPDATE_MANIFEST_CACHE_MS=15000
